Name: libavdevice
Description: FFmpeg device handling library
Version: 61.3.100
Requires: 
Requires.private: libavfilter >= 10.5.100, libswscale >= 8.3.100, libavformat >= 61.7.103, libavcodec >= 61.19.101, libswresample >= 5.3.100, libavutil >= 59.39.100
