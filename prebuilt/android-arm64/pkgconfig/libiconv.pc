prefix="/home/runner/work/ffmpeg-kit/ffmpeg-kit/prebuilt/android-arm64"/libiconv
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libiconv
Description: Character set conversion library
Version: 1.17

Requires:
Libs: -L${libdir} -liconv -lcharset
Cflags: -I${includedir}
