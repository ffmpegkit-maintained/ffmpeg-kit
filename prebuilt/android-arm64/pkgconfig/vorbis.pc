prefix="/home/runner/work/ffmpeg-kit/ffmpeg-kit/android-7.1-lts/prebuilt/android-arm64"/libvorbis
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: vorbis
Description: vorbis is the primary Ogg Vorbis library
Version: 1.3.7

Requires: ogg
Libs: -L${libdir} -lvorbis -lm
Cflags: -I${includedir}
