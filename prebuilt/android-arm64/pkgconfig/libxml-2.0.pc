prefix="/home/runner/work/ffmpeg-kit/ffmpeg-kit/prebuilt/android-arm64"/libxml2
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include
modules=1

Name: libXML
Version: 2.11.4
Description: libXML library version2.
Requires: libiconv
Libs: -L${libdir} -lxml2
Libs.private:   -lz -lm
Cflags: -I${includedir} -I${includedir}/libxml2
