# Opus codec reference implementation pkg-config file

prefix=/home/runner/work/ffmpeg-kit/ffmpeg-kit/android-7.1-lts/prebuilt/android-arm64/opus
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: Opus
Description: Opus IETF audio codec (floating-point, custom modes build)
URL: https://opus-codec.org/
Version: 1.4
Requires:
Conflicts:
Libs: -L${libdir} -lopus
Libs.private: -lm
Cflags: -I${includedir}/opus
