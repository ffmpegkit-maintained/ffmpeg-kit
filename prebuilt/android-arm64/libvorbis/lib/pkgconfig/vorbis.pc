# libvorbis pkg-config source file

prefix=/home/runner/work/ffmpeg-kit/ffmpeg-kit/android-6.0-lts/prebuilt/android-arm64/libvorbis
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: vorbis
Description: vorbis is the primary Ogg Vorbis library
Version: 1.3.7
Requires.private: ogg
Conflicts:
Libs: -L${libdir} -lvorbis 
Libs.private: -lm
Cflags: -I${includedir}
